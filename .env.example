# Copy to .env and adjust. All values are optional; defaults shown.

# Where the DuckDB file lives (inside the container this is /app/data/token.duckdb)
TD_DB_PATH=./data/token.duckdb

# Local timezone used to bucket usage into calendar days (IANA name).
# Logs are stored in UTC; the heatmap buckets by THIS zone.
TZ=America/New_York

# Comma-separated roots to scan. Defaults to the host home dirs below.
# In docker-compose these are mounted read-only at /data/claude and /data/codex.
TD_CLAUDE_ROOT=~/.claude/projects
TD_CODEX_ROOT=~/.codex/sessions

# Re-ingest interval (minutes) for the in-process scheduler.
TD_INGEST_INTERVAL_MIN=15

# Path to the editable pricing table.
TD_PRICING_PATH=./pricing.yaml

# Optional plan limits for utilization gauges (tokens). Leave unset to hide gauges.
# 5-hour rolling window (Anthropic rate-limit "block") and weekly window.
# TD_LIMIT_5H_TOKENS=
# TD_LIMIT_WEEK_TOKENS=

# HTTP port the app serves on.
TD_PORT=8080
